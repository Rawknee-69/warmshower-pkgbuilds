install=$pkgname.install
# warmshower.gpg must contain the WarmShower OS signing key generated in WS-001.
# DO NOT commit the private key.  Only the exported public key (.gpg) goes here.
# Regenerate sha512sums after updating key material: makepkg -g
source=("warmshower.gpg"
        "warmshower-revoked"
        "warmshower-trusted"
        "$install")

