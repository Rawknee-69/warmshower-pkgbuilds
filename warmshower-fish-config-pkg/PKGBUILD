# Maintainer: WarmShower OS <admin@warmshower.ai>

pkgname=warmshower-fish-config
pkgver=15
pkgrel=2
pkgdesc="Fish configuration of WarmShower OS"
arch=('any')
url="https://github.com/Warm-shower/$pkgname"
license=('MIT')
depends=(
  bat
  expac
  eza
  fastfetch
  fish
  fish-autopair
  fish-pure-prompt
  fisher
  fzf
  pkgfile
  tealdeer
  ttf-fantasque-nerd
)
makedepends=(
  git
)
conflicts=('warmshower-fish-config' 'kwin-scripts-window-colors')
replaces=('warmshower-fish-config')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz"
        "$pkgname.install")
# TODO (WS-021): Replace SKIP with real sha256sums.
# SKIP is only valid for VCS (git+/svn+/hg+/bzr+) sources.
# A static GitHub release tarball MUST have a real checksum.
# To generate: download the tarball and run:
#   sha256sum warmshower-fish-config-15.tar.gz
#   sha256sum warmshower-fish-config.install
# Then replace the two SKIP values below.
sha256sums=('SKIP'
            'SKIP')

package() {
  cd "$srcdir/$pkgname-$pkgver"

  install -D -m644 conf.d/done.fish $pkgdir/usr/share/warmshower-fish-config/conf.d/done.fish
  install -D -m644 warmshower-config.fish $pkgdir/usr/share/warmshower-fish-config/warmshower-config.fish
  install -D -m644 config.fish $pkgdir/etc/skel/.config/fish/config.fish
}

