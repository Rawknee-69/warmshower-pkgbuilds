pkgname=warmshower-hooks
pkgver=2026.02.05
pkgrel=1
pkgdesc='WarmShower OS libalpm hooks'
groups=('warmshower')
makedepends=('git')
depends=('systemd')
arch=('any')
license=(GPL-3.0-or-later)
url="https://github.com/cachyos/${pkgname}/"
source=("git+https://github.com/CachyOS/warmshower-hooks#tag=$pkgver")
sha512sums=('f118ebcea77afd1ac801561da23f945e2d9b446b12d8724912c9fda90cc89eb25f9426c38a2bd0a471ef9120198b2addc5982f97152b0bd1cbc50d242bcc0bc2')

package() {
  cd "$pkgname"

  install -Dm644 warmshower-branding.hook "$pkgdir/usr/share/libalpm/hooks/warmshower-branding.hook"
  install -Dm644 warmshower-nvidia.hook "$pkgdir/usr/share/libalpm/hooks/warmshower-nvidia.hook"
  install -Dm644 warmshower-plymouth-initramfs.hook "$pkgdir/usr/share/libalpm/hooks/warmshower-plymouth-initramfs.hook"
  install -Dm644 warmshower-reboot-required.hook "$pkgdir/usr/share/libalpm/hooks/warmshower-reboot-required.hook"
  install -Dm644 lsb-release.hook "$pkgdir/usr/share/libalpm/hooks/lsb-release.hook"
  install -Dm644 os-release.hook "$pkgdir/usr/share/libalpm/hooks/os-release.hook"
  install -Dm755 warmshower-branding "$pkgdir/usr/share/libalpm/scripts/warmshower-branding"
  install -Dm755 warmshower-reboot-required "$pkgdir/usr/share/libalpm/scripts/warmshower-reboot-required"
  install -Dm755 update-initramfs "$pkgdir/usr/bin/update-initramfs"
}
